# Required
ANTHROPIC_API_KEY=sk-ant-...
BRAVE_API_KEY=BSA...

# Optional — Bluesky publishing
BLUESKY_HANDLE=yourname.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Optional — Government data
FRED_API_KEY=...

# Optional — tuning
